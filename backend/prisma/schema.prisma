generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  username  String?  @unique
  password  String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  projects Project[]
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  SUCCESS
  ERROR
}

enum PreviewStatus {
  IDLE
  SCHEDULED
  RUNNING
}

enum DeploymentStatus {
  IDLE
  SCHEDULED
  RUNNING
}

enum KeyStoreStatus {
  IDLE
  SCHEDULED
  RUNNING
}

enum ApkStatus {
  IDLE
  SCHEDULED
  RUNNING
}

model ExpoDocs {
  id        String                 @id @default(cuid())
  content   String?
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now()) @db.Timestamptz(3)
}

model NativeWindDocs {
  id        String                 @id @default(cuid())
  content   String?
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now()) @db.Timestamptz(3)
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  previewStatus    PreviewStatus @default(IDLE)
  previewStartedAt DateTime?     @db.Timestamptz(3)

  deploymentStatus    DeploymentStatus @default(IDLE)
  deploymentStartedAt DateTime?        @db.Timestamptz(3)

  keyStoreStatus    KeyStoreStatus @default(IDLE)
  keyStoreStartedAt DateTime?      @db.Timestamptz(3)

  apkStatus    ApkStatus @default(IDLE)
  apkStartedAt DateTime? @db.Timestamptz(3)

  messages    Message[]
  apks        APK[]
  keyStore    KeyStore?
  deployments Deployment[]
  secrets     Secret[]
  previews    Preview[]
}

model Preview {
  id        String   @id @default(cuid())
  url       String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stream    Stream?

  @@index([projectId])
}

model Secret {
  id             String   @id @default(cuid())
  name           String
  encryptedValue Bytes
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
}

model APK {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Required Back-relation
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stream    Stream?
}

model Message {
  id        String      @id @default(cuid())
  content   String
  role      MessageRole
  type      MessageType
  createdAt DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt DateTime    @updatedAt @db.Timestamptz(3)
  completed Boolean     @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fragmentId String?   @unique
  fragment   Fragment? @relation(fields: [fragmentId], references: [id])
  stream     Stream?
}

model Fragment {
  id             String   @id @default(cuid())
  content        String
  frontendTarKey String?
  backendTarKey  String?
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  message Message?
}

model KeyStore {
  id        String   @id @default(cuid())
  password  Bytes?
  data      Bytes?
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Required Back-relation (1-to-1 requires @unique)
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stream    Stream?
}

model Deployment {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stream    Stream?

  @@index([projectId])
}

model Stream {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // APK relation
  apkId String? @unique
  apk   APK?    @relation(fields: [apkId], references: [id], onDelete: Cascade)

  // Deployment relation
  deploymentId String?     @unique
  deployment   Deployment? @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  // Project relation (optional if you want direct access)
  previewId String?  @unique
  preview   Preview? @relation(fields: [previewId], references: [id], onDelete: Cascade)

  keystoreId String?   @unique
  keystore   KeyStore? @relation(fields: [keystoreId], references: [id], onDelete: Cascade)

  messageId    String?       @unique
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  streamChunks StreamChunk[]
}

model StreamChunk {
  id        String   @id @default(cuid())
  data      Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
}
