generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ExpoDocs {
  id        String                 @id @default(cuid())
  content   String?
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now()) @db.Timestamptz(3)
}

model NativeWindDocs {
  id        String                 @id @default(cuid())
  content   String?
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now()) @db.Timestamptz(3)
}

model Project {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(3)
  
  messages   Message[]
  apks       APK[]
  keyStore   KeyStore?
  deployment Deployment?
}

model APK {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  
  // Required Back-relation
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Message {
  id         String    @id @default(cuid())
  content    String
  role       String    // Consider using an Enum: USER, AGENT, SYSTEM
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(3)
  
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fragmentId String?
  fragment   Fragment? @relation(fields: [fragmentId], references: [id])
}

model Fragment {
  id        String   @id @default(cuid())
  content   String
  codeTarId String?  // Maps to your Tigris S3 key
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Required Back-relation
  messages  Message[]
}

model KeyStore {
  id        String   @id @default(cuid())
  password  String
  data      Bytes
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Required Back-relation (1-to-1 requires @unique)
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deployment {
  id        String   @id @default(cuid())
  url       String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  // Required Back-relation (1-to-1 requires @unique)
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}